SECRET_KEY=change-me
DEBUG=False
# HRMS public hostname (nginx → APP_PORT on host, container listens on 8000).
# Add your server IP here only if you still hit the API by IP: host1,host2,...
ALLOWED_HOSTS=127.0.0.1,localhost,nexus-hrms.aspune.cloud
# Browser origins allowed to call this API (scheme + host + port). Include your Next.js dev port and production frontend.
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:6012,http://127.0.0.1:3000,http://127.0.0.1:6012,http://nexus-hrms.aspune.cloud,https://nexus-hrms.aspune.cloud,http://nexus-pms.aspune.cloud,https://nexus-pms.aspune.cloud

# Docker / Jenkins: host port mapped to container 8000
APP_PORT=6015

DB_NAME=attendace_pms
DB_USER=postgres
DB_PASSWORD=siva
DB_HOST=127.0.0.1
DB_PORT=5432

# Must match the PMS backend Django SECRET_KEY unless PMS is configured with a separate JWT signing key.
JWT_SECRET=django-insecure-change-me

# Optional fallback when using a legacy PMS token without role claims.
# Example: ADMIN_EMPLOYEE_IDS=15
ADMIN_EMPLOYEE_IDS=

# Used to resolve role for legacy tokens (new PMS logins embed role in the JWT).
# PMS API — production
PMS_API_BASE_URL=http://nexus-pms.aspune.cloud/api/v1
# Local PMS example: PMS_API_BASE_URL=http://127.0.0.1:8000/api/v1

# Admin/service JWT used to fetch employee emails from PMS for notifications.
PMS_SERVICE_TOKEN=

# Office timezone for 9:00 AM shift rules.
TIME_ZONE=Asia/Kolkata

# SMTP — use the same values as pms/.env (EMAIL_HOST, SMTP_USER, SMTP_PASS, etc.)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
SMTP_USER=your@gmail.com
SMTP_PASS=your-gmail-app-password
DEFAULT_FROM_EMAIL=your@gmail.com
